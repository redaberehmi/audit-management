# ==============================================================
# AUDIT MANAGEMENT — Variables Production
# Copier en .env et remplir toutes les valeurs avant déploiement
# NE JAMAIS committer ce fichier avec de vraies valeurs
# ==============================================================

# ── Environnement ──────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL ─────────────────────────────────────────────────
# Option A — Base cloud (Supabase / Railway / Render)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/audit_db?sslmode=require

# Option B — PostgreSQL local Docker (VPS self-hosted)
# DATABASE_URL=postgresql://audit_user:STRONG_PASSWORD@postgres:5432/audit_db

POSTGRES_USER=audit_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS
POSTGRES_DB=audit_db

# ── JWT (générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=GENERATE_64_CHAR_HEX_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_64_CHAR_HEX_HERE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── URLs ────────────────────────────────────────────────────────
# URL publique du frontend (votre domaine)
FRONTEND_URL=https://audit.votre-domaine.com

# URL publique de l'API backend (utilisée par le frontend)
NEXT_PUBLIC_API_URL=https://audit.votre-domaine.com/api
# Si backend sur sous-domaine séparé :
# NEXT_PUBLIC_API_URL=https://api.audit.votre-domaine.com/api

# ── SMTP (emails automatiques) ──────────────────────────────────
# Gmail App Password : https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_app_password_16_chars
SMTP_FROM="Audit Management <noreply@votre-domaine.com>"

# ── Stockage fichiers (Cloudflare R2 / AWS S3) ─────────────────
# Cloudflare R2 (gratuit jusqu'à 10GB, sans frais de sortie)
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=votre_account_id
R2_ACCESS_KEY_ID=votre_access_key
R2_SECRET_ACCESS_KEY=votre_secret_key
R2_BUCKET_NAME=audit-documents
R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# AWS S3 (alternative)
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=eu-west-1
# S3_BUCKET_NAME=audit-documents-prod

# ── Rate Limiting ───────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Backend port ────────────────────────────────────────────────
PORT=3001
